# teststop — Isolated Agent Development Environment
#
# Purpose: Run Claude Code / Copilot CLI agent in an isolated linux/arm64 container.
#          The agent can only touch the mounted /workspace (this repo).
#          No SDK, no API keys — agent shells out to claude/copilot CLI inside container.
#
# Build:  scripts/dev-container.sh  (handles build + run automatically)
# Manual: container build --tag teststop-dev:latest --file Dockerfile.dev .

FROM ubuntu:24.04

LABEL org.opencontainers.image.title="teststop-dev"
LABEL org.opencontainers.image.description="Isolated dev environment for teststop — Go + claude + copilot CLI"

ARG GO_VERSION=1.24.3

# ── Base toolchain ────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git bash unzip wget sudo \
    && rm -rf /var/lib/apt/lists/*

# ── Go ────────────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-arm64.tar.gz" \
    | tar -xz -C /usr/local
ENV PATH="/usr/local/go/bin:$PATH"
ENV CGO_ENABLED=0
ENV GOPATH=/go
ENV GOMODCACHE=/go/pkg/mod

# ── GitHub CLI (gh) ───────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=arm64 signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
        https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 (needed for GitHub Copilot CLI) ────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub Copilot CLI ────────────────────────────────────────────────────────
# Installs the `copilot` binary: used as teststop's AI backend (copilotcli.go)
# Also used directly inside container by the coding agent.
RUN npm install -g @githubnext/github-copilot-cli 2>/dev/null \
    || echo "⚠  copilot CLI install failed — gh copilot extension is the fallback"

# ── Claude Code CLI ───────────────────────────────────────────────────────────
# Installs the `claude` binary: used as teststop's AI backend (claudecli.go)
# Auth is provided via mounted ~/.claude at container runtime (read-only).
RUN curl -fsSL https://claude.ai/install.sh | bash \
    || echo "⚠  Claude CLI install failed — mount credentials and retry at runtime"
ENV PATH="/root/.claude/local/bin:/root/.local/bin:$PATH"

# ── Git config ────────────────────────────────────────────────────────────────
# Teach git to trust /workspace (it's a cross-device mount from macOS host)
RUN git config --global --add safe.directory /workspace

# ── Go module cache (pre-warm in a writable layer, not from host) ─────────────
RUN mkdir -p /go/pkg/mod /go/bin
VOLUME ["/go/pkg/mod"]

WORKDIR /workspace

CMD ["/bin/bash", "--login"]
